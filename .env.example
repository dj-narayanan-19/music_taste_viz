# Copy this file to .env and fill in your keys. Never commit .env.
#
# Last.fm API key — free at https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here

# Spotify — create an app at https://developer.spotify.com/dashboard
# Set the redirect URI to http://localhost:8888/callback in your app settings
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
